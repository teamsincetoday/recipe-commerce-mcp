{
  "name": "recipe-commerce-mcp",
  "version": "0.1.2",
  "description": "Recipe Commerce Intelligence MCP Server - Extract recipes and ingredients from cooking video transcripts, match to purchasable products, and build affiliate shopping lists for agents.",
  "type": "module",
  "license": "MIT",
  "author": "Since Today Studio <team@sincetoday.com>",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "recipe-commerce-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "openai": "^6.25.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "recipe",
    "commerce",
    "ingredients",
    "affiliate",
    "cooking",
    "ai-agent",
    "agent-to-agent"
  ]
}
